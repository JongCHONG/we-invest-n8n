      "id": "44eb2cde-750e-4008-ad2d-b293c7625d13",
      "name": "Data Validation"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const data = $json;\n\nconst leadId = `lead-${Date.now()}`;\nconst receivedAt = new Date().toISOString();\nconst priority = data.budget > 450000 ? 'high' : 'normal';\n\nconst summary = `${data.firstName} ${data.lastName || ''}`.trim()\n  + ` est un lead ${data.projectType} à ${data.city}`\n  + (data.budget ? ` avec un budget de ${data.budget}` : '');\n\nreturn {\n  json: {\n    ...data,\n    leadId,\n    receivedAt,\n    priority,\n    summary,\n  },\n};"
      },
