    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const data = $json.body ?? $json;\n\nconst required = ['firstName', 'email', 'projectType', 'city'];\nconst missing = required.filter((field) => !data[field] || String(data[field]).trim() === '');\n\nreturn {\n  json: {\n    ...data,\n    isValid: missing.length === 0,\n    missingFields: missing,\n    errorMessage: missing.length ? `Missing fields required: ${missing.join(', ')}` : null,\n  },\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -320,
        -96
